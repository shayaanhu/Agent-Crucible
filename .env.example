# ── Required ────────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model to use for the red-team agent and LlamaGuard detector.
# Default works fine — only change if you want a different Groq model.
GROQ_MODEL=openai/gpt-oss-120b

# ── Optional: Blue-team adapters ─────────────────────────────────────────────
# Both default to enabled but gracefully fall back to rules-only if the
# underlying libraries are not installed. Leave them as-is for a basic demo.

BLUE_TEAM_ENABLE_LLAMA_GUARD=1
BLUE_TEAM_ENABLE_NEMO_GUARDRAILS=1

# Override the HuggingFace model used by LlamaGuard (requires `transformers`).
# BLUE_TEAM_LLAMA_GUARD_MODEL=meta-llama/Llama-Guard-3-8B

# Path to a NeMo Guardrails config directory (requires `nemoguardrails`).
# BLUE_TEAM_NEMO_CONFIG_PATH=config/nemo
